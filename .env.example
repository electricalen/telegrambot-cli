# Copy to `.env` and fill in values. Do not commit `.env`.
#
#   cp .env.example .env

# Required
TELEGRAM_BOT_TOKEN=your_token_from_botfather
TELEGRAM_OWNER_IDS=123456789

# Optional — polling / logging
# TELEGRAM_POLLING_TIMEOUT_SEC=30
# TELEGRAM_LOG_LEVEL=INFO

# Optional — heartbeat (JobQueue)
# TELEGRAM_HEARTBEAT_ENABLED=true
# TELEGRAM_HEARTBEAT_INTERVAL_SEC=900
# TELEGRAM_HEARTBEAT_MESSAGE=Heartbeat

# Optional — custom monitors interval (when any @register_monitor is used)
# TELEGRAM_MONITOR_INTERVAL_SEC=120

# Optional — use a different env file path (absolute or ~)
# TELEGRAM_ENV_FILE=/path/to/other.env
